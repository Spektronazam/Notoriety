local function fireHit(tool: Tool, hitPart: BasePart): boolean
    if not tool or not hitPart then return false end

    return safeCall(function()
        local rs: Instance? = getRS()
        if not rs then return end

        local remotes: Instance? = rs:FindFirstChild("Assets") and rs.Assets:FindFirstChild("Remotes")
        local hitRemote: RemoteEvent? = remotes and remotes:FindFirstChild("HitObject") :: RemoteEvent?

        if hitRemote then
            local args: {any} = {
                [1] = tool,
                [2] = hitPart,
                [3] = false,
                [6] = Vector3.new(0, 0, 0),
                [7] = 90,
                [9] = hitPart.Position,
            }
            hitRemote:FireServer(table.unpack(args, 1, 9))
        end
    end, "Error firing HitObject remote")
end

-- ==================== OZELA HEIST HELPERS ====================
type BoxCodeInfo = {
    codes: {{number: number, title: string, isCorrect: boolean}},
    correctCode: string,
    correctTitle: string,
    colorSequence: string,
    colorBoxName: string
}

local function detectColorBoxCode(): BoxCodeInfo
    local result: BoxCodeInfo = {
        codes = {},
        correctCode = "",
        correctTitle = "",
        colorSequence = "",
        colorBoxName = "",
    }

    safeCall(function()
        local cardReader: Instance? = Workspace:FindFirstChild("prop_stadium_cardReader")
        if cardReader then
            local main: Instance? = cardReader:FindFirstChild("main")
            local serial: Instance? = main and main:FindFirstChild("serial")
            local surfaceGui: Instance? = serial and serial:FindFirstChild("SurfaceGui")
            local textLabel: TextLabel? = surfaceGui and surfaceGui:FindFirstChild("TextLabel") :: TextLabel?
            if textLabel and textLabel.Text ~= "" then
                result.correctCode = textLabel.Text
            end
        end

        local blueprints: Instance? = Workspace:FindFirstChild("Blueprints")
        if blueprints then
            local stadiumBlueprint: Instance? = blueprints:FindFirstChild("prop_stadium_blueprintTableRNG")
            local blueprint: Instance? = stadiumBlueprint and stadiumBlueprint:FindFirstChild("prop_stadium_blueprint")
            if blueprint then
                for i = 1, 3 do
                    local numbered: Instance? = blueprint:FindFirstChild(tostring(i))
                    local serial: Instance? = numbered and numbered:FindFirstChild("serial")
                    local surfaceGui: Instance? = serial and serial:FindFirstChild("SurfaceGui")
                    local textLabel: TextLabel? = surfaceGui and surfaceGui:FindFirstChild("TextLabel") :: TextLabel?

                    if textLabel and textLabel.Text ~= "" then
                        local codeTitle: string = textLabel.Text

                        if codeTitle == result.correctCode and result.correctCode ~= "" then
                            result.correctTitle = codeTitle
                            local colors: Instance? = numbered and numbered:FindFirstChild("colors")
                            if colors then
                                local colorParts: {string} = {}
                                for j = 1, 4 do
                                    local colorPart: Instance? = colors:FindFirstChild(tostring(j))
                                    local colorSurface: Instance? = colorPart and colorPart:FindFirstChild("SurfaceGui")
                                    local colorLabel: TextLabel? = colorSurface and colorSurface:FindFirstChild("TextLabel") :: TextLabel?
                                    if colorLabel and colorLabel.Text ~= "" then
                                        table.insert(colorParts, colorLabel.Text)
                                    end
                                end
                                result.colorSequence = table.concat(colorParts, " ")
                            end
                        end

                        table.insert(result.codes, {
                            number = i,
                            title = codeTitle,
                            isCorrect = (codeTitle == result.correctCode and result.correctCode ~= ""),
                        })
                    end
                end
            end
        end

        local colorBoxRNG: Instance? = Workspace:FindFirstChild("colorBoxRNG")
        if colorBoxRNG and result.correctTitle ~= "" then
            for _, colorBox: Instance in ipairs(colorBoxRNG:GetChildren()) do
                local serial: Instance? = colorBox:FindFirstChild("serial")
                local surfaceGui: Instance? = serial and serial:FindFirstChild("SurfaceGui")
                local textLabel: TextLabel? = surfaceGui and surfaceGui:FindFirstChild("TextLabel") :: TextLabel?
                if textLabel and textLabel.Text == result.correctTitle then
                    result.colorBoxName = colorBox.Name
                    break
                end
            end
        end
    end, "Error detecting color box code")

    return result
end

local function getUSBComputerStatus(): string
    local status: string = "Not found"
    safeCall(function()
        local usbComputer: Instance? = Workspace:FindFirstChild("UsedUSBComputer")
        local screen: Instance? = usbComputer and usbComputer:FindFirstChild("Screen")
        local surfaceGui: Instance? = screen and screen:FindFirstChild("SurfaceGui")
        local textLabel: TextLabel? = surfaceGui and surfaceGui:FindFirstChild("TextLabel") :: TextLabel?
        if textLabel and textLabel.Text ~= "" then
            status = textLabel.Text
        end
    end, "Error getting USB status")
    return status
end

local function updateColorBoxStatus(): BoxCodeInfo?
    if not codeStatusLabel then return nil end

    local info: BoxCodeInfo = detectColorBoxCode()
    local codeText: string = "Color Box Code Detection:\n\n"

    if #info.codes > 0 then
        codeText = codeText .. "Codes:\n"
        for _, code in ipairs(info.codes) do
            local marker: string = code.isCorrect and "[OK]" or "[X]"
            codeText = codeText .. string.format("  %s #%d: %s\n", marker, code.number, code.title)
        end
        codeText = codeText .. "\n"
    else
        codeText = codeText .. "No codes detected\n\n"
    end

    if info.correctCode ~= "" then
        codeText = codeText .. "Correct Code: " .. info.correctCode .. "\n"
    else
        codeText = codeText .. "Correct code not found\n"
    end

    if info.colorSequence ~= "" then
        codeText = codeText .. "Colors: " .. info.colorSequence .. "\n"
    end

    if info.colorBoxName ~= "" then
        codeText = codeText .. "Box: " .. info.colorBoxName
    end

    codeStatusLabel:SetText(codeText)
    return info
end

local function updateUSBStatus()
    if not usbStatusLabel then return end
    local status: string = getUSBComputerStatus()
    usbStatusLabel:SetText("USB Computer Code:\n\n" .. status)
end

-- ==================== FAST INTERACT STEP ====================
local function fastInteractStep()
    if not fastInteractEnabled then return end
    if not (fastInteract_UseFireProx or fastInteract_UsePromptEvents or fastInteract_UseKeyPress) then
        return
    end

    local now: number = os.clock()
    if now - fastInteractLastRun < 0.15 then return end
    fastInteractLastRun = now

    local character: Model? = LocalPlayer.Character
    local hrp: BasePart? = character and character:FindFirstChild("HumanoidRootPart") :: BasePart?
    if not hrp then return end

    for prompt: ProximityPrompt in pairs(fastInteractPrompts) do
        if prompt and prompt.Parent and prompt.Enabled and prompt.MaxActivationDistance > 0 then
            local targetPart: BasePart?

            if prompt.Adornee and prompt.Adornee:IsA("BasePart") then
                targetPart = prompt.Adornee
            else
                local parent: Instance? = prompt.Parent
                if parent and parent:IsA("BasePart") then
                    targetPart = parent
                elseif parent then
                    targetPart = parent:FindFirstChildWhichIsA("BasePart", true)
                end
            end

            if targetPart then
                local dist: number = (hrp.Position - targetPart.Position).Magnitude
                if dist <= (prompt.MaxActivationDistance + 3) then
                    if fastInteract_UseFireProx and typeof(fireproximityprompt) == "function" then
                        pcall(function() fireproximityprompt(prompt, math.huge) end)
                    end

                    if fastInteract_UsePromptEvents then
                        pcall(function()
                            prompt:InputHoldBegin()
                            task.delay(0.05, function()
                                if prompt.Parent and prompt.Enabled then
                                    pcall(function() prompt:InputHoldEnd() end)
                                end
                            end)
                        end)
                    end

                    if fastInteract_UseKeyPress and VirtualInputManager then
                        local key: Enum.KeyCode = prompt.KeyboardKeyCode ~= Enum.KeyCode.Unknown and prompt.KeyboardKeyCode or Enum.KeyCode.E
                        pcall(function()
                            VirtualInputManager:SendKeyEvent(true, key, false, game)
                            task.delay(0.05, function()
                                VirtualInputManager:SendKeyEvent(false, key, false, game)
                            end)
                        end)
                    end
                end
            end
        end
    end
end

