-- ==================== AIM FUNCTIONS ====================
local function getClosestPolice(): Model?
    local closest: Model? = nil
    local shortestDistance: number = aimFOV

    for _, folderName: string in ipairs({ "Police", "Bodies" }) do
        local folder: Instance? = Workspace:FindFirstChild(folderName)
        if folder then
            for _, npc: Instance in ipairs(folder:GetChildren()) do
                if npc:IsA("Model") then
                    local targetPart: BasePart? = npc:FindFirstChild(aimPart) :: BasePart?
                    if targetPart then
                        local humanoid: Humanoid? = npc:FindFirstChildOfClass("Humanoid")
                        if humanoid and humanoid.Health > 0 then
                            local screenPos: Vector3, onScreen: boolean = Camera:WorldToViewportPoint(targetPart.Position)
                            if onScreen then
                                local mousePos: Vector2 = Vector2.new(Mouse.X, Mouse.Y)
                                local targetPos: Vector2 = Vector2.new(screenPos.X, screenPos.Y)
                                local distance: number = (mousePos - targetPos).Magnitude
                                if distance < shortestDistance then
                                    closest = npc
                                    shortestDistance = distance
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    return closest
end

local function aimAtTarget(target: Model?)
    if not target then return end
    local targetPart: BasePart? = target:FindFirstChild(aimPart) :: BasePart?
    if not targetPart then return end

    local targetPos: Vector3 = targetPart.Position
    local cameraPos: Vector3 = Camera.CFrame.Position

    if useSensitivity then
        local lookAt: CFrame = CFrame.new(cameraPos, targetPos)
        local lerpAmount: number = aimSensitivity / 100
        Camera.CFrame = Camera.CFrame:Lerp(lookAt, lerpAmount)
    else
        Camera.CFrame = CFrame.new(cameraPos, targetPos)
    end
end

