local function getEquippedWeapon(): Tool?
    local character: Model? = LocalPlayer.Character
    if not character then return nil end
    return character:FindFirstChildOfClass("Tool")
end

local function getOriginalWeaponEntry(dataModule: ModuleScript, weaponData: { [string]: any }): OriginalWeaponEntry
    local entry: OriginalWeaponEntry? = OriginalWeaponData[dataModule]
    if entry then return entry end

    entry = {}
    local baseKeys: {string} = {
        "Damage", "FireDelay", "MagazineSize", "AmmoMax",
        "ReloadTime", "LongerReloadTime", "Accuracy",
    }

    for _, key: string in ipairs(baseKeys) do
        local value: any = weaponData[key]
        if typeof(value) == "number" then entry[key] = value end
    end

    for key: string, value: any in pairs(weaponData) do
        if typeof(value) == "number" then
            local lower: string = string.lower(key)
            if lower:find("damage") and entry[key] == nil then
                entry[key] = value
            end
        end
    end

    OriginalWeaponData[dataModule] = entry
    return entry
end

local function buffCurrentWeapon()
    safeCall(function()
        local criminals: Instance? = Workspace:FindFirstChild("Criminals")
        if not criminals then
            notify("Weapon Mod", "Criminals folder not found", 3)
            return
        end

        local charFolder: Instance? = criminals:FindFirstChild(LocalPlayer.Name)
        if not charFolder then
            notify("Weapon Mod", "You are not in Criminals!", 3)
            return
        end

        local function scaleField(tbl: any, key: string, factor: number, minValue: number?, maxValue: number?, orig: any?)
            local base: number = orig and orig[key] or tbl[key]
            if typeof(base) == "number" then
                local new: number = base * factor
                if minValue or maxValue then
                    new = math.clamp(new, minValue or -math.huge, maxValue or math.huge)
                end
                tbl[key] = new
            end
        end

        local ammoNames: {string} = { "Ammo", "StoredAmmo", "ReserveAmmo", "MaxAmmo", "AmmoMax", "TotalAmmo", "CurrentAmmo" }
        local magNames: {string} = { "MagSize", "Magazine", "Clip", "ClipSize", "CurrentClip" }

        local function scaleIntValuesInGun(root: Instance, factorAmmo: number, factorMag: number)
            for _, v: Instance in ipairs(root:GetDescendants()) do
                if v:IsA("IntValue") then
                    if table.find(ammoNames, v.Name) then
                        local base: any = v:GetAttribute("SocrateS_OrigAmmo")
                        if base == nil then
                            base = v.Value
                            v:SetAttribute("SocrateS_OrigAmmo", base)
                        end
                        local new: number = math.floor(base * factorAmmo)
                        v.Value = math.clamp(new, 0, 99999)
                    elseif table.find(magNames, v.Name) then
                        local base: any = v:GetAttribute("SocrateS_OrigMag")
                        if base == nil then
                            base = v.Value
                            v:SetAttribute("SocrateS_OrigMag", base)
                        end
                        local new: number = math.floor(base * factorMag)
                        v.Value = math.clamp(new, 1, 1000)
                    end
                end
            end
        end

        local weaponsToBuff: {Instance} = {}

        if buffEquippedOnly then
            local equipped: Tool? = getEquippedWeapon()
            if not equipped then
                notify("Weapon Mod", "No equipped weapon found", 3)
                return
            end
            table.insert(weaponsToBuff, equipped)
        else
            weaponsToBuff = charFolder:GetChildren()
        end

        local buffed: number = 0

        for _, obj: Instance in ipairs(weaponsToBuff) do
            local dataModule: Instance? = obj:FindFirstChild("Data")
            if dataModule and dataModule:IsA("ModuleScript") then
                local weaponData: any = require(dataModule)
                if typeof(weaponData) == "table" then
                    local s: WeaponBuffSettings = WeaponBuffSettings
                    local orig: OriginalWeaponEntry = getOriginalWeaponEntry(dataModule, weaponData)

                    for key: string, base: any in pairs(orig) do
                        if typeof(base) == "number" then
                            local lower: string = string.lower(key)
                            if lower:find("damage") then
                                local cur: any = weaponData[key]
                                if typeof(cur) == "number" then
                                    local new: number = base * s.Damage
                                    weaponData[key] = math.clamp(new, 1, 10000)
                                end
                            end
                        end
                    end

                    if typeof(orig.FireDelay) == "number" then
                        local fireFactor: number = 1 / math.max(s.FireRate, 0.1)
                        weaponData.FireDelay = math.clamp(orig.FireDelay * fireFactor, 0.03, 1)
                    end

                    scaleField(weaponData, "MagazineSize", s.Magazine, 1, 1000, orig)
                    scaleField(weaponData, "AmmoMax",      s.Ammo,     1, 5000, orig)

                    if typeof(orig.ReloadTime) == "number" then
                        local reloadFactor: number = 1 / math.max(s.Reload, 0.1)
                        weaponData.ReloadTime = math.clamp(orig.ReloadTime * reloadFactor, 0.1, 10)
                    end

                    if typeof(orig.LongerReloadTime) == "number" then
                        local reloadFactor: number = 1 / math.max(s.Reload, 0.1)
                        weaponData.LongerReloadTime = math.clamp(orig.LongerReloadTime * reloadFactor, 0.1, 10)
                    end

                    scaleField(weaponData, "Accuracy", s.Accuracy, 0, 100, orig)
                    scaleIntValuesInGun(obj, s.Ammo, s.Magazine)

                    buffed += 1
                end
            end
        end

        if buffed > 0 then
            local scope: string = buffEquippedOnly and "equipped weapon" or ("weapon(s): " .. buffed)
            notify("Weapon Mod", ("Buff applied to %s"):format(scope), 4)
        else
            notify("Weapon Mod", "No weapon data modules found to modify", 3)
        end
    end, "Error modifying weapon")
end

