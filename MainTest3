                                    local radius: number = 1.5
                                    local angle: number = t * 6 + i
                                    local heightJitter: number = math.sin(t * 10 + i) * 0.25

                                    local offset: Vector3 = Vector3.new(
                                        math.cos(angle) * radius,
                                        baseY + heightJitter,
                                        math.sin(angle) * radius
                                    )
                                    ammoPart.CFrame = hrp.CFrame * CFrame.new(offset.X, offset.Y, offset.Z)
                                end
                            end
                        end
