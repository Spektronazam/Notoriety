                    safeCall(function()
                        local character: Model? = LocalPlayer.Character
                        local hrp: BasePart? = character and character:FindFirstChild("HumanoidRootPart") :: BasePart?
                        local ammoDrops: Instance? = Workspace:FindFirstChild("AmmoDrops")
                        if not hrp or not ammoDrops then return end

                        local t: number = os.clock()
                        for i, drop: Instance in ipairs(ammoDrops:GetChildren()) do
                            if drop:IsA("Model") then
                                local ammoPart: BasePart? = drop:FindFirstChild("AmmoPart") :: BasePart?
