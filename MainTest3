-- ==================== ACTOR WORKER ====================
-- Uses executor Actors library if present (Madium / Synapse / etc.)
local hasActorAPI: boolean = typeof(run_on_actor) == "function"
    and typeof(create_comm_channel) == "function"
    and typeof(get_comm_channel) == "function"
    and typeof(getactors) == "function"

local ActorWorker = {
    use = hasActorAPI,
    channelId = nil :: string?,
    channel = nil :: any?,
}

if ActorWorker.use then
    local actors: {Actor} = getactors()
    local actor: Actor? = actors[1]

    if not actor then
        actor = Instance.new("Actor")
        actor.Name = "SocrateS_WorkerActor"
        actor.Parent = Workspace
    end

    local id: string, channel: any = create_comm_channel("SocrateS_Worker")
    ActorWorker.channelId = id
    ActorWorker.channel = channel

    local okActor: boolean, errActor: string = pcall(function()
        run_on_actor(actor, [[
            local Workspace: Workspace = game:GetService("Workspace")
            local Players: Players = game:GetService("Players")

            local function safeCall(fn: () -> ()): boolean
                local ok: boolean, err: string = pcall(fn)
                if not ok then
                    warn("[SocrateS/Actor] " .. tostring(err))
                end
                return ok
            end

            local function createHighlight(object: Instance, color: Color3): Highlight?
                if not object or not object:IsDescendantOf(Workspace) then
                    return nil
                end

                local highlight: Highlight = Instance.new("Highlight")
                highlight.FillColor = color
                highlight.OutlineColor = color
                highlight.FillTransparency = 0.4
                highlight.OutlineTransparency = 0
                highlight.Adornee = object
                highlight.Parent = object

                return highlight
            end

            local function clearHighlights(tbl: {Highlight?})
                for i = #tbl, 1, -1 do
                    local hl: Highlight? = tbl[i]
                    if hl then
                        safeCall(function()
                            hl:Destroy()
                        end)
                    end
                    tbl[i] = nil
                end
            end

            -- ESP state
            local cameraESPEnabled: boolean = false
            local policeESPEnabled: boolean = false
            local civilianESPEnabled: boolean = false
            local keyCardESPEnabled: boolean = false
            local ropeESPEnabled: boolean = false
            local hookESPEnabled: boolean = false
            local codeTableESPEnabled: boolean = false

            local cameraHighlights: {Highlight?} = {}
            local policeHighlights: {Highlight?} = {}
            local civilianHighlights: {Highlight?} = {}
            local keyCardHighlights: {Highlight?} = {}
            local ropeHighlights: {Highlight?} = {}
            local hookHighlights: {Highlight?} = {}
            local codeTableHighlights: {Highlight?} = {}

            local function updateESP()
                -- Cameras
                if cameraESPEnabled then
                    clearHighlights(cameraHighlights)
                    safeCall(function()
                        for _, folderName: string in ipairs({ "Cameras", "BrokenCameras" }) do
                            local folder: Instance? = Workspace:FindFirstChild(folderName)
                            if folder then
                                for _, cam: Instance in ipairs(folder:GetChildren()) do
                                    local color: Color3 = (folderName == "BrokenCameras")
                                        and Color3.fromRGB(255, 165, 0)
                                        or Color3.fromRGB(255, 0, 0)
                                    local hl: Highlight? = createHighlight(cam, color)
                                    if hl then table.insert(cameraHighlights, hl) end
                                end
                            end
                        end
                    end)
                else clearHighlights(cameraHighlights) end

                -- Police / Bodies
                if policeESPEnabled then
                    clearHighlights(policeHighlights)
                    safeCall(function()
                        for _, folderName: string in ipairs({ "Police", "Bodies" }) do
                            local folder: Instance? = Workspace:FindFirstChild(folderName)
                            if folder then
                                for _, cop: Instance in ipairs(folder:GetChildren()) do
                                    local hl: Highlight? = createHighlight(cop, Color3.fromRGB(0, 100, 255))
                                    if hl then table.insert(policeHighlights, hl) end
                                end
                            end
                        end
                    end)
                else clearHighlights(policeHighlights) end

                -- Citizens
                if civilianESPEnabled then
                    clearHighlights(civilianHighlights)
                    safeCall(function()
                        local citizens: Instance? = Workspace:FindFirstChild("Citizens")
                        if citizens then
                            for _, citizen: Instance in ipairs(citizens:GetChildren()) do
                                local isTied: number? = citizen.Name:lower():find("tied")
                                local color: Color3 = isTied and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(0, 255, 0)
                                local hl: Highlight? = createHighlight(citizen, color)
                                if hl then table.insert(civilianHighlights, hl) end
                            end
                        end
                    end)
                else clearHighlights(civilianHighlights) end

                -- KeyCards
                if keyCardESPEnabled then
                    clearHighlights(keyCardHighlights)
                    safeCall(function()
                        local map: Instance? = Workspace:FindFirstChild("Map")
                        if map then
                            local keyCardFolder: Instance? = map:FindFirstChild("KeyCard")
                            if keyCardFolder then
                                local keyCard: Instance? = keyCardFolder:FindFirstChild("KeyCard")
                                if keyCard then
                                    local hl: Highlight? = createHighlight(keyCard, Color3.fromRGB(255, 215, 0))
                                    if hl then table.insert(keyCardHighlights, hl) end
                                end
                            end
                        end
                    end)
                else clearHighlights(keyCardHighlights) end

                -- Ozela: Ropes
                if ropeESPEnabled then
                    clearHighlights(ropeHighlights)
                    safeCall(function()
                        local mapEntities: Instance? = Workspace:FindFirstChild("mapEntities")
                        if mapEntities then
                            local missionItems: Instance? = mapEntities:FindFirstChild("missionItems")
                            if missionItems then
                                local ropes: Instance? = missionItems:FindFirstChild("Ropes")
                                if ropes then
                                    for _, rope: Instance in ipairs(ropes:GetChildren()) do
                                        local hl: Highlight? = createHighlight(rope, Color3.fromRGB(255, 255, 0))
                                        if hl then table.insert(ropeHighlights, hl) end
                                    end
                                end
                            end
                        end
                    end)
                else clearHighlights(ropeHighlights) end

                -- Ozela: Hooks
                if hookESPEnabled then
                    clearHighlights(hookHighlights)
                    safeCall(function()
                        local mapEntities: Instance? = Workspace:FindFirstChild("mapEntities")
                        if mapEntities then
                            local missionItems: Instance? = mapEntities:FindFirstChild("missionItems")
                            if missionItems then
                                local hooks: Instance? = missionItems:FindFirstChild("Hooks")
                                if hooks then
                                    for _, hook: Instance in ipairs(hooks:GetChildren()) do
                                        local hl: Highlight? = createHighlight(hook, Color3.fromRGB(0, 255, 100))
                                        if hl then table.insert(hookHighlights, hl) end
                                    end
                                end
                            end
                        end
                    end)
                else clearHighlights(hookHighlights) end

                -- Ozela: Code Table
                if codeTableESPEnabled then
                    clearHighlights(codeTableHighlights)
                    safeCall(function()
                        local blueprints: Instance? = Workspace:FindFirstChild("Blueprints")
                        if blueprints then
                            local stadiumBlueprint: Instance? = blueprints:FindFirstChild("prop_stadium_blueprintTableRNG")
                            if stadiumBlueprint then
                                local codeTable: Instance? = stadiumBlueprint:FindFirstChild("prop_office_TablePlastic")
                                if codeTable then
                                    local hl: Highlight? = createHighlight(codeTable, Color3.fromRGB(200, 0, 255))
                                    if hl then table.insert(codeTableHighlights, hl) end
                                end
                            end
                        end
                    end)
                else clearHighlights(codeTableHighlights) end
            end

            -- BringGuards / Kill All state
            local bringGuardsEnabled: boolean = false
            local guardStackDistance: number = 10
            local guardFacingMode: string = "Face You"

            local function bringGuardsStep()
                if not bringGuardsEnabled then return end

                local localPlayer: Player? = Players.LocalPlayer
                if not localPlayer then return end

                local character: Model? = localPlayer.Character
                if not character then return end

                local hrp: BasePart? = character:FindFirstChild("HumanoidRootPart") :: BasePart?
                if not hrp then return end

                local baseStackCFrame: CFrame = hrp.CFrame * CFrame.new(0, 0, -guardStackDistance)

                for _, folderName: string in ipairs({ "Police", "Bodies" }) do
                    local folder: Instance? = Workspace:FindFirstChild(folderName)
                    if folder then
                        for _, npc: Instance in ipairs(folder:GetChildren()) do
                            local npcHrp: BasePart? = npc:FindFirstChild("HumanoidRootPart") :: BasePart?
                            local humanoid: Humanoid? = npc:FindFirstChildOfClass("Humanoid")

                            if npcHrp and humanoid and humanoid.Health > 0 then
                                local stackPos: Vector3 = baseStackCFrame.Position
                                local toPlayer: CFrame = CFrame.new(stackPos, hrp.Position)
                                if guardFacingMode == "Back To You" then
                                    toPlayer = toPlayer * CFrame.Angles(0, math.rad(180), 0)
                                end

                                npcHrp.CFrame = toPlayer
                                npcHrp.Anchored = true
                            end
                        end
                    end
                end
            end

            local channelId: string = ...
            local channel: any = get_comm_channel(channelId)
            local eventSignal = channel.Event or channel

            eventSignal:Connect(function(msgType: string, ...: any)
                local args: {any} = { ... }

                if msgType == "SetCameraESP" then cameraESPEnabled = not not args[1]
                elseif msgType == "SetPoliceESP" then policeESPEnabled = not not args[1]
                elseif msgType == "SetCivilianESP" then civilianESPEnabled = not not args[1]
                elseif msgType == "SetKeyCardESP" then keyCardESPEnabled = not not args[1]
                elseif msgType == "SetRopeESP" then ropeESPEnabled = not not args[1]
                elseif msgType == "SetHookESP" then hookESPEnabled = not not args[1]
                elseif msgType == "SetCodeTableESP" then codeTableESPEnabled = not not args[1]
                elseif msgType == "SetBringGuards" then
                    bringGuardsEnabled = not not args[1]
                    if typeof(args[2]) == "number" then guardStackDistance = math.clamp(args[2], 1, 10) end
                    if typeof(args[3]) == "string" then guardFacingMode = args[3] end
                end
            end)

            task.spawn(function()
                while true do
                    safeCall(updateESP)
                    task.wait(2)
                end
            end)

            task.spawn(function()
                while true do
                    safeCall(bringGuardsStep)
                    task.wait(0.1)
                end
            end)
        ]], id)
    end)

    if not okActor then
        warn("[SocrateS] Actor API failed to initialize: " .. tostring(errActor))
        ActorWorker.use = false
    end
else
    warn("[SocrateS] Actor API not available – using Task Scheduler fallbacks.")
end

local function sendToWorker(msgType: string, ...: any)
    if ActorWorker.use and ActorWorker.channel then
        ActorWorker.channel:Fire(msgType, ...)
    end
end

local function spawnWorker(fn: () -> ())
    task.spawn(fn)
end

