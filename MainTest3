local function cleanup()
    autoHoldM1Enabled = false
    fastInteractEnabled = false
    instantGuardSyncEnabled = false

    clearHighlightsMain(cameraHighlights)
    clearHighlightsMain(policeHighlights)
    clearHighlightsMain(civilianHighlights)
    clearHighlightsMain(keyCardHighlights)
    clearHighlightsMain(ropeHighlights)
    clearHighlightsMain(hookHighlights)
    clearHighlightsMain(codeTableHighlights)

    if ActorWorker.use then
        sendToWorker("SetCameraESP", false)
        sendToWorker("SetPoliceESP", false)
        sendToWorker("SetCivilianESP", false)
        sendToWorker("SetKeyCardESP", false)
        sendToWorker("SetRopeESP", false)
        sendToWorker("SetHookESP", false)
        sendToWorker("SetCodeTableESP", false)
        sendToWorker("SetBringGuards", false, guardStackDistance, guardFacingMode)
    end

    if FOVCircle then pcall(function() FOVCircle:Remove() end) end

    if tpWalkConnection then tpWalkConnection:Disconnect(); tpWalkConnection = nil end
    if infJumpConnection then infJumpConnection:Disconnect(); infJumpConnection = nil end
    if noclipLoop then noclipLoop:Disconnect(); noclipLoop = nil end
    if gravityLoop then gravityLoop:Disconnect(); gravityLoop = nil end
    if infiniteStaminaLoop then infiniteStaminaLoop:Disconnect(); infiniteStaminaLoop = nil end
    if instantInteractConnection then instantInteractConnection:Disconnect(); instantInteractConnection = nil end
    if autoAmmoLoop then autoAmmoLoop:Disconnect(); autoAmmoLoop = nil end
    if autoHoldM1Loop then autoHoldM1Loop:Disconnect(); autoHoldM1Loop = nil end
    if instantGuardSyncConnection then instantGuardSyncConnection:Disconnect(); instantGuardSyncConnection = nil end

    if autoHoldM1Holding and VirtualInputManager then
        autoHoldM1Holding = false
        local mousePos: Vector2 = UserInputService:GetMouseLocation()
        pcall(function() VirtualInputManager:SendMouseButtonEvent(mousePos.X, mousePos.Y, 0, false, game, 1) end)
    end

    safeCall(function()
        for part: BasePart, wasCollide: boolean in pairs(noclipParts) do
            if part and part.Parent then part.CanCollide = wasCollide end
            noclipParts[part] = nil
        end
    end)

    visualKillAllActive = false
    autoRefreshUSBEnabled = false
    ropeESPEnabled = false
    hookESPEnabled = false
    codeTableESPEnabled = false
    cameraESPEnabled = false
    policeESPEnabled = false
    civilianESPEnabled = false
    keyCardESPEnabled = false
    autoAmmoEnabled = false
    autoHoldM1Enabled = false
    instantGuardSyncEnabled = false
    fastInteractEnabled = false
    fastInteract_UseFireProx = false
    fastInteract_UsePromptEvents = false
    fastInteract_UseKeyPress = false

    Workspace.Gravity = 196.2
    notify("SocrateS", "Cleanup completed!", 2)
end

Players.LocalPlayer.OnTeleport:Connect(cleanup)

