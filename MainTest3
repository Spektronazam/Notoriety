local function trackFastInteractPrompt(obj: Instance)
    if not (obj and obj:IsA("ProximityPrompt")) then return end
    fastInteractPrompts[obj] = true

    obj.AncestryChanged:Connect(function(_, parent)
        if not parent then
            fastInteractPrompts[obj] = nil
        end
    end)
end

