        Callback = function(value: boolean)
            autoAmmoEnabled = value
            if autoAmmoLoop then
                autoAmmoLoop:Disconnect()
                autoAmmoLoop = nil
            end

            if value then
                autoAmmoLoop = RunService.Heartbeat:Connect(function()
