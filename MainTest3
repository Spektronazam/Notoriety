do
    local StatsGroup = Tabs.Stats:AddLeftGroupbox("Player Statistics", "bar-chart")

    local statsLabel = StatsGroup:AddLabel("Your Statistics\n\nPress refresh to load.", true)

    StatsGroup:AddButton({
        Text = "Refresh", Tooltip = "Load stats from server",
        Func = function()
            safeCall(function()
                local rs: Instance? = getRS()
                local remotes: Instance? = rs and rs:FindFirstChild("Remotes")
                local getStats: RemoteFunction? = remotes and remotes:FindFirstChild("GetStats") :: RemoteFunction?

                if not getStats then
                    notify("Stats", "Stats remote not found!", 3)
                    return
                end

                notify("Stats", "Loading statistics...", 2)
                local stats: any = getStats:InvokeServer()

                if not stats then
                    statsLabel:SetText("Error loading statistics.\nTry again in a few seconds.")
                    notify("Stats", "Failed to load stats!", 3)
                    return
                end

                local t: string = "Your Statistics:\n\n"
                t = t .. "Kills:\n"
                t = t .. "  Police: " .. tostring(stats.PoliceKills or 0) .. "\n"
                t = t .. "  Civilians: " .. tostring(stats.CivilianKills or 0) .. "\n"
                t = t .. "  Headshots: " .. tostring(stats.Headshots or 0) .. "\n\n"
                t = t .. "Money:\n"
                t = t .. "  Instant Cash: $" .. tostring(stats.InstantCash or 0) .. "\n\n"
                t = t .. "Support:\n"
                t = t .. "  Revives: " .. tostring(stats.Revives or 0) .. "\n"
                t = t .. "  Downs: " .. tostring(stats.Downs or 0) .. "\n\n"
                t = t .. "Weapon Stats:\n"

                if stats.GunStats and typeof(stats.GunStats) == "table" then
                    local hasGun: boolean = false
                    for gunName: string, gunData: any in pairs(stats.GunStats) do
                        if typeof(gunData) == "table" then
                            hasGun = true
                            t = t .. "  " .. gunName .. ":\n"
                            if gunData.Kills then t = t .. "    Kills: " .. tostring(gunData.Kills) .. "\n" end
                            if gunData.Shots then t = t .. "    Shots: " .. tostring(gunData.Shots) .. "\n" end
                            if gunData.Headshots then t = t .. "    Headshots: " .. tostring(gunData.Headshots) .. "\n" end
                        end
                    end
                    if not hasGun then t = t .. "  No weapon stats recorded\n" end
                else t = t .. "  No weapon stats available\n" end

                t = t .. "\nInteractions:\n"
                t = t .. "  Total: " .. tostring(stats.Interactions or 0)

                statsLabel:SetText(t)
                notify("Stats", "Stats loaded!", 3)
            end, "Error loading statistics")
        end,
    })

